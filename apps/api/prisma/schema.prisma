generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  displayName       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userRoles         UserRole[]
  auditEvents       AuditEvent[]       @relation("AuditActor")
  vercelConnections VercelConnection[]
  templates         DeploymentTemplate[]
  deployments       DeploymentJob[]
}

model Role {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model VercelConnection {
  id                String          @id @default(cuid())
  userId            String
  name              String
  vercelUserId      String?
  vercelEmail       String?
  vercelUsername    String?
  teamId            String?
  teamSlug          String?
  plan              String?
  encryptedToken    String
  tokenStatus       String          @default("valid")
  lastValidatedAt   DateTime?
  lastHealthCheckAt DateTime?
  lastUsageSyncAt   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments    DeploymentJob[]
  usageSnapshots UsageSnapshot[]
  usageServices  UsageService[]

  @@index([userId])
}

model DeploymentTemplate {
  id              String                      @id @default(cuid())
  userId          String
  name            String
  description     String?
  sourceType      String
  artifactPath    String
  variablesSchema Json?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  user        User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments DeploymentJob[]
  versions    DeploymentTemplateVersion[]

  @@index([userId])
}

model DeploymentTemplateVersion {
  id              String   @id @default(cuid())
  templateId      String
  version         Int
  artifactPath    String
  variablesSchema Json?
  changelog       String?
  createdAt       DateTime @default(now())

  template    DeploymentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  deployments DeploymentJob[]

  @@unique([templateId, version])
  @@index([templateId])
}

model DeploymentJob {
  id                   String   @id @default(cuid())
  userId               String
  templateId           String
  templateVersionId    String?
  connectionId         String
  name                 String
  target               String   @default("preview")
  status               String   @default("queued")
  renderPayload        Json?
  renderedArtifactPath String?
  deploymentUrl        String?
  deploymentDomain     String?
  providerDeploymentId String?
  logs                 Json?
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        DeploymentTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion DeploymentTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  connection      VercelConnection           @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([templateVersionId])
  @@index([connectionId])
  @@index([status])
}

model UsageSnapshot {
  id           String   @id @default(cuid())
  connectionId String
  periodStart  DateTime
  periodEnd    DateTime
  source       String
  rawPayload   Json
  createdAt    DateTime @default(now())

  connection VercelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  services   UsageService[]

  @@index([connectionId, createdAt])
}

model UsageService {
  id                 String   @id @default(cuid())
  snapshotId         String
  connectionId       String
  periodStart        DateTime
  periodEnd          DateTime
  serviceName        String
  quantity           Float
  unit               String
  includedLimit      Float?
  estimatedRemaining Float?
  effectiveCost      Float?
  billedCost         Float?
  createdAt          DateTime @default(now())

  snapshot UsageSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  connection VercelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([connectionId, serviceName, createdAt])
}
